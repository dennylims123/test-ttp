// TTP (Traceability to Plantation) Form Database Schema

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
  // When using a driver adapter (PrismaLibSql), the URL here is only used for
  // prisma db push / migrate. At runtime, the adapter handles the connection.
  // We use a env var with a fallback so Prisma doesn't crash at build/runtime
  // when only the adapter is providing the real connection.
  url = env("DATABASE_URL")
}

/// A PKS (Pabrik Kelapa Sawit) account that can submit TTP reports.
/// Auth is via simple 6-digit PIN.
model PksAccount {
  id        String   @id @default(cuid())
  name      String   @unique
  pin       String   // 6-digit PIN
  createdAt DateTime @default(now())

  reports TtpReport[]

  @@map("pks_accounts")
}

/// A saved TTP form report (a PKS can have multiple reporting periods)
model TtpReport {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Owner (PKS account) — nullable for legacy reports created before auth
  pksAccountId String?
  pksAccount   PksAccount? @relation(fields: [pksAccountId], references: [id], onDelete: SetNull)

  // Status: "DRAFT" (editable by PKS) | "PUBLISHED" (locked for PKS, admin can revert)
  status      String   @default("DRAFT")
  publishedAt DateTime?

  // PKS info
  pksName      String?
  pksAddress   String?
  pksLatitude  String?
  pksLongitude String?
  reportDate   String?
  periode      String?
  totalTbs     Float?
  pengisi      String?

  // P1M data
  p1mProduksiTbsBersertifikat Float?
  p1mKapasitasPks             Float?
  p1mProduksiCpo              Float?
  p1mFasilitasKernel          String? // Y / T
  p1mTotalTbs                 Float?
  p1mTbsKebunInti             Float?
  p1mTbsPlasma                Float?
  p1mTbsMandiri               Float?
  p1mSistemTtp                String? // Y / T
  p1mNilaiTtp                 Float?
  p1mSistemDetail             String?

  suppliers     SupplierTbs[]
  agenPengumpul AgenPengumpul[]

  @@map("ttp_reports")
}

/// Internal (Kebun Inti/Plasma) or External (Perusahaan/Pribadi/Agen/Koperasi/Gapoktan)
model SupplierTbs {
  id        String @id @default(cuid())
  reportId  String
  report    TtpReport @relation(fields: [reportId], references: [id], onDelete: Cascade)

  section      String  // "internal" | "external"
  no           Int
  namaPemasok  String?
  jenisPemasok String? // Kebun Inti / Plasma / Perusahaan Perkebunan Pihak Ketiga / etc.
  jumlahPetani Int?
  sertifikasi  String? // Ya / Tidak
  desa         String?
  kecamatan    String?
  kabupaten    String?
  lintang      String?
  bujur        String?
  legalitas    String? // HGU/SHM/SKT/SKGR
  luasAreal    Float?
  petaKebun    String? // Ya / Tidak
  volumeTbs    Float?

  @@map("supplier_tbs")
}

/// Phase 2B - Agen/Pengumpul (Indirect supplier with farmer list)
/// Linked to a SupplierTbs row via linkedSupplierNo (the supplier's `no` field, scoped to section='external')
model AgenPengumpul {
  id        String @id @default(cuid())
  reportId  String
  report    TtpReport @relation(fields: [reportId], references: [id], onDelete: Cascade)

  no           Int
  namaAgen     String?
  alamat       String?
  lintang      String?
  bujur        String?
  desaSumber   String?
  volumeTbs    Float?

  /// Link to the SupplierTbs row (section='external', jenisPemasok='Agen / Pengumpul / Ramp')
  /// Stores the supplier's `no` value (1-23). NULL = unlinked/manual entry (legacy).
  linkedSupplierNo Int?

  farmers Farmer[]

  @@map("agen_pengumpul")
}

/// Farmer under an Agen/Pengumpul
model Farmer {
  id        String @id @default(cuid())
  agenId    String
  agen      AgenPengumpul @relation(fields: [agenId], references: [id], onDelete: Cascade)

  no         Int
  nama       String?
  lintang    String?
  bujur      String?
  legalitas  String?
  desa       String?
  kecamatan  String?
  kabupaten  String?
  luasKebun  Float?

  @@map("farmer")
}

/// Master village data (18k+ rows from MSD SSD sheet)
model Village {
  id        Int    @id
  desa      String
  full      String

  @@index([desa])
  @@map("villages")
}
