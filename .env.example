# Database — use Turso (managed SQLite) for production on Vercel
# Get these from https://turso.tech after creating a database
DATABASE_URL="libsql://your-db-name-your-username.turso.io"
DATABASE_AUTH_TOKEN="your-turso-auth-token-here"

# Admin PIN for accessing Rekap Admin (/#admin)
# Change this to a secret PIN before deploying!
ADMIN_PIN="123456"
